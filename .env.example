# Copiar a .env y rellenar. No subas .env al repositorio.

# Obligatorio en producción (clave aleatoria larga)
SECRET_KEY=cambia-esto-por-una-cadena-larga-y-aleatoria

# Stripe (pagos con tarjeta; opcional en desarrollo)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# Correo saliente (opcional; Flask-Mail)
MAIL_USERNAME=
MAIL_PASSWORD=
